$]=/weOgBDY_7Exg(s|X"><value name="IF0"><shadow type="logic_boolean" id="-/fWEtk)CJ|X3^+$.]2d"><field name="BOOL">FALSE</field></shadow></value><statement name="DO0"><block type="quest_Note_6_quest_Show_String_For_Note_Big_Func" id="c3n*@`Q=/jd,I2AC?j}_"><value name="textStrIn"><shadow type="text" id="@8Jav^T0d5kUeq-G=4Mk"><field name="TEXT">Staff: Very Important Notes</field></shadow></value><next><block type="controls_if" id="%frH_:)I*bJ?](lqB=Ir"><value name="IF0"><shadow type="logic_boolean" id="N#e)o25/ZG0Ar`5)wwZR"><field name="BOOL">FALSE</field></shadow></value><statement name="DO0"><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="ZsrR|BKmE},5psiFNEVp"><value name="textStrIn"><shadow type="text" id="16b=FRYLG`@4[RM6UXLM"><field name="TEXT">Levels 1, 2, 2.1</field></shadow></value><next><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="`.3$yo-cy(t:/B1cIg%p"><value name="textStrIn"><shadow type="text" id="B~DU=f09N[B#oUFD|_b?"><field name="TEXT">* Level 1: Hardcoded Static via Actual_Numbers for MotorPower%</field></shadow></value><next><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="U2b7ATBNNVt?:;4KQLk("><value name="textStrIn"><shadow type="text" id="aVKM=_14Z2`+;%Yp!sT;"><field name="TEXT">* Level 2: Softcoded Dynamic via Variables/Constants for MotorPower% </field></shadow></value><next><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="yBb+/hr-xU2k4PD#Hj@W"><value name="textStrIn"><shadow type="text" id="3|lK4D(~IFlvqv]n^#h|"><field name="TEXT">* Level 2.1 Add Controller_Joystick * Level 2.2 Add Gear 3 (90%?)</field></shadow></value></block></next></block></next></block></next></block></statement><next><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="TbEg7b7da*6JE.B|Exg!"><value name="textStrIn"><shadow type="text" id="k!lOQzf|pC0kJ5~R/D6*"><field name="TEXT">Basic Comment_Colors Usage:: Black: Very Big Picture, Blue: Big Picture, Green: Following Block_Code Moddable, Orange: Question/TODO, Magenta: Special Multi-Purpose </field></shadow></value><next><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="3cIXrO.Vj9;x??qPP[iE"><value name="textStrIn"><shadow type="text" id="p6EC7t}0d?GL:D@U;7Bq"><field name="TEXT">micro:bit Ver2 Warning during Download is Ignorable Yet Courteously Helpful</field></shadow></value><next><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="i!e6zmv@,XfnydXqDuOa"><value name="textStrIn"><shadow type="text" id="QlR;9Wb!9C6;xQ4BVc%7"><field name="TEXT">'if_then' mini-stacks useful for modular 3-D code select/duplicate/move/delete</field></shadow></value><next><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id=";r=dgl|G/VZHpx,|mZ[2"><value name="textStrIn"><shadow type="text" id="tdCerb/Kd~.:XqLQLz=z"><field name="TEXT">Light_Gray Functions non-editable (backend staff-use code only)</field></shadow></value><next><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id=";QLtxF*1aT1wieMT82`g"><value name="textStrIn"><shadow type="text" id=":nv2^XS[$#I_5YV/y%*K"><field name="TEXT">For Group_CHannel_# (Bot_Id): Propose: 1-10 Staff Use, 11-99 Student Use</field></shadow></value><next><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="K4)]l3z#M7BuG^=_k;oS"><value name="textStrIn"><shadow type="text" id="NCJND8JM5g?nouriiaI("><field name="TEXT">SW Reset: Long_Press Logo for 3 sec min</field></shadow></value><next><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="$gtiGqn%H0+C%4t1|2bF"><value name="textStrIn"><shadow type="text" id="ADh%KEgpgfm9%I[bf6X$"><field name="TEXT">Built-in Diagnostic Test: Short_Press Logo for 1 sec max</field></shadow></value><next><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="j$yvDxr1;L!U`{hFtT,c"><value name="textStrIn"><shadow type="text" id="g(:@7t{I$|:P-7bjFm*0"><field name="TEXT">'Blocks' Window homes 'on start'_stack as top_left corner of editor_screen, until 'on start' is moved below, then next stack to right presides</field></shadow></value><next><block type="quest_Note_3_quest_Show_String_For_Note_Small_Func" id="udNL^r~c3rrIs#=t!rPj"><value name="textStrIn"><shadow type="text" id="b!`ihhS/%/@t^AU3|E+("><field name="TEXT">All These Levels are Intermediate Level Coding due to Networking Pairing Involved.  Basic Diagnostic Servo_Motors (Autonomoous) is Beginner Level.</field></shadow></value><next><block type="quest_Note_3_quest_Show_String_For_Note_Small_Func" id="~1:%SF1sot,Ga76+CG]6"><value name="textStrIn"><shadow type="text" id="(Zc+LfllN3D9f44E,ZE*"><field name="TEXT">This Intermediate Level Network_Pairing has 1sec_Lag Response Time; The Other Advanced Level Network_Pairing has Real_Time Response Time.</field></shadow></value><next><block type="quest_Note_3_quest_Show_String_For_Note_Small_Func" id="J-*C%W|N{um.Hjh-9k@p"><value name="textStrIn"><shadow type="text" id="Lx:~daS|v7].(v=treDw"><field name="TEXT">For Level 1, can keep 'Forward: set manual_servo_motors' Block functional, yet reset to 0 all other 'set manual_servo_motors' Blocks for Discovery Learning</field></shadow></value><next><block type="quest_Note_3_quest_Show_String_For_Note_Small_Func" id="YUQyZOE[6lbZc!R-e.d$"><value name="textStrIn"><shadow type="text" id="JnY}jz%9c{/`~Uan-FZ#"><field name="TEXT">If duplicate stacks exist, then the highest stack is active and others are non_active</field></shadow></value></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement><next><block type="controls_if" id="QokH8rgmg[`ZS6Ryh!mQ"><value name="IF0"><shadow type="logic_boolean" id="W`SYW~I7sJ,P2rB0SjK9"><field name="BOOL">FALSE</field></shadow></value><statement name="DO0"><block type="quest_Note_6_quest_Show_String_For_Note_Big_Func" id="9YMXUaTGddB5}:lhL_Fd"><value name="textStrIn"><shadow type="text" id="^pa2d97)bIBdh^_h(HX:"><field name="TEXT">Staff: Important Notes</field></shadow></value><next><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="LS,gu8TeBbi+RanI{#(|"><value name="textStrIn"><shadow type="text" id="-ll_iH#j0TzLW^6~Vyt~"><field name="TEXT">Upon open file, Editor zooms in on closest stack to right of original_origin from project_creation</field></shadow></value><next><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="BJ{3Q+ei8|?qrzBI*MAE"><value name="textStrIn"><shadow type="text" id="y9VMJhJ}7]@}X3yrUQtX"><field name="TEXT">Semantic Naming prefers '_' vs. '-' since latter can be conufused with minus_sign</field></shadow></value><next><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="U69AW_`o=PGtk9D0K%Fx"><value name="textStrIn"><shadow type="text" id="BeFuWiw6KWq/-ksO]6*,"><field name="TEXT">'every 360000 ms' (1 hour) Stacks can be ignored, esp w/ 'if false' embedded</field></shadow></value><next><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="kW`luU)7/#!@d_L0Y2Jd"><value name="textStrIn"><shadow type="text" id="(6Ql}Es-:~0$.%1jQVe2"><field name="TEXT">Avoid using 'show leds' Block since will cause lag &amp; degrade real-time response</field></shadow></value><next><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="|l3oBjMMM:AhMqrc0y=g"><value name="textStrIn"><shadow type="text" id="AJqoc-oD63mci;kj2$d;"><field name="TEXT">Seems like 'signficant' changes to JavaScript can activate 'format code', rearrange stacks to original position</field></shadow></value><next><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="gEn3E_QDYprnkYi}[]63"><value name="textStrIn"><shadow type="text" id="=qnqcTRj1E,WyB:8F@2$"><field name="TEXT">Important 'system' variables are 1) _system_Hw_DeviceType__* (Hw=Hardware) and 2) _system_Sw_ModeState__* (Sw=Software)</field></shadow></value><next><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="v$(VQ/$)V4hc8$RZr,pI"><value name="textStrIn"><shadow type="text" id="2O`qi47j[}QbYFC*/c=U"><field name="TEXT">If Buttons C-F for Gears/Misc, Maybe 'Logo Up/Down' for 'Servo_Arm Up/Down'</field></shadow></value><next><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="-]bq7`%#Z_p3{d(mHuT;"><value name="textStrIn"><shadow type="text" id="_hsDv+B^UYQ.)4:Y0u:h"><field name="TEXT">'Rotatedisplay' could be used on Bot's Led_Screen, but causes light flickering on bottom row, so maybe avoid</field></shadow></value><next><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="WT8:^:|!ADuSX5^_Xj.B"><value name="textStrIn"><shadow type="text" id="KXV3Ea%{ymY{VgzrMl-@"><field name="TEXT">Reliable/Faster Response If Screen_Led_Graphics After Important Action Blocks Above</field></shadow></value><next><block type="controls_if" id="+pasa_1=V5HB0U@0nv{U"><value name="IF0"><shadow type="logic_boolean" id="|UdmXIHU7H(P4@io2)!@"><field name="BOOL">FALSE</field></shadow></value><statement name="DO0"><block type="quest_Note_3_quest_Show_String_For_Note_Small_Func" id="/L1HR|LutW=8a=tjJZ*r"><value name="textStrIn"><shadow type="text" id="a2u4vIZjI=`196$DDeNN"><field name="TEXT">Main upgrade from Lv1 to Lv2 is replacing cpu_laggy 'show leds' block with cpu_fast 'plox x _ y _' block, such as below: </field></shadow></value><next><block type="controls_if" id="$hK0vl.w;A=m|Ugt,L=]"><mutation elseif="4" else="1"></mutation><value name="IF0"><shadow type="logic_boolean" id="`|iKp6WUq`KJuAT/E8+u"><field name="BOOL">FALSE</field></shadow></value><statement name="DO0"><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="%-9:It4Rq=dR$F?]r#x`"><value name="textStrIn"><shadow type="text" id="peS~SJg)qi-~*Hi`lq)="><field name="TEXT">West</field></shadow></value><next><block type="quest_Note_1_quest_Show_String_For_Note_Small_Func" id="OW7#cI}Q,{I*WlXbW4%]"><value name="textStrIn"><shadow type="text" id="B$DgnnzU2jumtEHOVa{v"><field name="TEXT">L